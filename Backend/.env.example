# File ini adalah contoh konfigurasi environment variable
# Salin file ini dan rename menjadi .env
# Sesuaikan nilai di bawah ini dengan konfigurasi database kamu

# Konfigurasi Server
PORT=3000

# Konfigurasi Database MySQL
DB_HOST=localhost       # Host database (default: localhost)
DB_USER=root            # Username database
DB_PASSWORD=            # Password database (kosongkan jika tidak ada)
DB_NAME=redesign        # Nama database